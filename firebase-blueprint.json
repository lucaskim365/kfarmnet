{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Authenticated user profile data",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A conversation session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "updatedAt", "createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "image": {
          "type": "object",
          "properties": {
            "mimeType": { "type": "string" },
            "data": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "text", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Collections of chat sessions"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat session"
    },
    "admins/{adminId}": {
      "schema": "User",
      "description": "System administrators list"
    }
  }
}
